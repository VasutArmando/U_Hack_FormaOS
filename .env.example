# =======================================================
# FORMA OS - Template Variabile de Mediu
# =======================================================
# AVERTISMENT SECRETS SCANNER: Nu scrie NICIODATĂ chei reale în acest fișier.
# Copiază acest fișier sub numele de '.env' și populează-l strict local.

# --- GENERAL CONFIG ---
DEMO_MODE=true
ENVIRONMENT=development
PORT=8080

# --- GOOGLE CLOUD PROJECT ---
GCP_PROJECT_ID=forma-os-hackathon-XXXX
GCP_REGION=europe-west4

# --- FIREBASE & AUTHENTICATION ---
FIREBASE_PROJECT_ID=forma-os-firebase
FIREBASE_WEB_API_KEY=YOUR_FIREBASE_API_KEY_HERE
# Calea locală către JSON-ul service account descărcat din GCP (Nu va fi comitat pe GitHub)
GOOGLE_APPLICATION_CREDENTIALS=./config/service-account.json

# --- VERTEX AI / GEMINI LLM ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# --- REDIS / CELERY ---
REDIS_URL=redis://localhost:6379/0

# --- EDGE ML / COMPUTER VISION ---
EDGE_NODE_WSS_ENDPOINT=wss://forma-os.cloud/ingest
